# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- Database ---
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://bumssistant:devpassword@localhost:5432/bumssistant

# --- Auth: Microsoft Entra ID (leave blank on a private laptop) ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# DEV ONLY: skip real SSO and log in as a fake local user. MUST be false in production.
DEV_AUTH_BYPASS=true
DEV_USER_EMAIL=dev@bumg.de
DEV_USER_NAME=Dev User

# --- LLM gateway: Langdock (EU-hosted, DSGVO-compliant) ---
LANGDOCK_API_KEY=
LANGDOCK_BASE_URL=https://api.langdock.com
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- Warm-start scan (anti-cold-start) ---
# subjects_only  -> calendar/Jira metadata + email SUBJECTS only; raw subjects discarded after summary.
# mock           -> synthetic data only (default & enforced on private laptops).
# off            -> no scan.
# HARD RULE: real employee data is only scanned when ENVIRONMENT=production. Locally this is forced to 'mock'.
WARM_START_SCAN_MODE=mock

# --- Environment ---
ENVIRONMENT=development   # development | production
